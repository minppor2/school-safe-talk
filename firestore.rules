rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isStaff() { return signedIn() && profile().role in ['teacher', 'department', 'admin']; }
    function isAdmin() { return signedIn() && profile().role == 'admin'; }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /cases/{caseId} {
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.authorId == request.auth.uid ||
        resource.data.assigneeId == request.auth.uid ||
        request.auth.uid in resource.data.sharedWith ||
        isAdmin()
      );
      allow update: if signedIn() && (
        resource.data.authorId == request.auth.uid ||
        resource.data.assigneeId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();

      match /timeline/{entryId} {
        allow read: if signedIn() && (
          get(/databases/$(database)/documents/cases/$(caseId)).data.authorId == request.auth.uid ||
          isStaff()
        );
        allow create: if signedIn();
        allow update, delete: if isAdmin();
      }
    }

    match /departments/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /faq/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if false;
    }
  }
}
