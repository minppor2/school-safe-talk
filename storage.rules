rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /case-files/{caseId}/{fileName} {
      allow read, write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('(image/.*|application/pdf|text/plain)');
    }
  }
}
